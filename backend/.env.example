# 1С OData (тестовая база)
ODATA_BASE_URL=http://91.144.178.239:8888/test_moskva/odata/standard.odata/
ODATA_LOGIN=Абсалямов Роман
ODATA_PASSWORD=
ODATA_TIMEOUT=30
ODATA_RETRIES=3

# Bitrix24 (заполнить позже)
# Вебхук формата: https://portal.bitrix24.ru/rest/<user_id>/<token>/
# Нужны права im и disk.
BITRIX_WEBHOOK_URL=
# ID чата, например chat226489 из /online/?IM_DIALOG=chat226489.
BITRIX_CHAT_ID=

# Email SMTP (для отправки xlsx вложением)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_LOGIN=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
# Несколько адресов можно разделить запятыми или точками с запятой.
EMAIL_TO=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0

# Автоматическая генерация и рассылка
SCHEDULE_ENABLED=0
SCHEDULE_DAILY_ENABLED=1
SCHEDULE_DAILY_TIME=11:00
SCHEDULE_WEEKLY_ENABLED=1
# День недели cron: 0/7 воскресенье, 1 понедельник, 5 пятница.
SCHEDULE_WEEKLY_DAY=5
SCHEDULE_WEEKLY_TIME=11:00
SCHEDULE_SEND_BITRIX=1
SCHEDULE_SEND_EMAIL=0

# Web UI
# Web UI не использует порты 80/443. Для прямого доступа к VPS используется 8080.
# Для reverse proxy можно поставить WEB_UI_HOST=127.0.0.1.
WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=8080
WEB_UI_USER=admin
WEB_UI_PASSWORD=
