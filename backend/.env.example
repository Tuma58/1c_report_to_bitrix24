# ID папки Диска, куда загружать xlsx перед отправкой ссылок в чат.
BITRIX_DISK_FOLDER_ID=

# Web UI
# Web UI не использует порты 80/443. Для прямого доступа к VPS используется 8080.
# Для reverse proxy можно поставить WEB_UI_HOST=127.0.0.1.
WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=8080
WEB_UI_USER=admin
WEB_UI_PASSWORD=

# OpenAI GPT (для MCP-агента)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7
